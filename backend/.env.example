# Local dev env — copy this file to `.env` and fill in your own values.
# NEVER put real credentials in this .env.example file — it is committed to
# git and is meant to be a template only. `.env` itself is gitignored.
#
# SECURITY NOTE: this file previously contained real, live MongoDB Atlas and
# Cloudinary credentials. If you inherited a `.env` copied from the old
# version of this file, or any deploy that used those values, you MUST
# rotate them now — they are considered permanently compromised:
#   - MongoDB Atlas: change the database user's password (Atlas > Database
#     Access), and update every deployment's MONGO_URI.
#   - Cloudinary: regenerate the API secret (Cloudinary dashboard >
#     Settings > Security), and update every deployment's
#     CLOUDINARY_API_SECRET.
#   - JWT_SECRET: generate a new one (see below) and redeploy — this
#     invalidates all existing admin/user sessions, which is expected.

PORT=5000

# Format: mongodb+srv://<user>:<password>@<cluster-host>/<db-name>?...
MONGO_URI=mongodb+srv://your_db_user:your_db_password@your-cluster.mongodb.net/groxo?retryWrites=true&w=majority

# Generate a strong random value, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# The app will now refuse to start if this is missing — there is no
# insecure fallback.
JWT_SECRET=replace_with_a_long_random_generated_secret

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Comma-separated list of origins allowed to call this API from a browser
# (the admin panel). See server.js.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional — used only by seeders/adminSeeder.js to create the first admin
# account. If left unset, the seeder generates a random password and
# prints it once to the console instead of using a hardcoded default.
SEED_ADMIN_PHONE=
SEED_ADMIN_PASSWORD=

# Used by services/emailService.js to send the OTP for
# POST /auth/forgot-password when the account has an email on file. If a
# wholesaler only has a phone on file, the OTP goes through utils/sendOTP.js
# instead (currently just console.logs it — wire in a real SMS provider,
# e.g. Twilio, which is already a dependency, before relying on this in
# production).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
